<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>致顾斐老师</title>
    <style>
        body {
            margin: 0; padding: 0;
            background-color: #ffe6ea;
            overflow: hidden;
            font-family: "Microsoft YaHei", sans-serif;
            height: 100vh; width: 100vw;
            display: flex; justify-content: center; align-items: center;
        }
        #welcome-screen {
            text-align: center; position: absolute; z-index: 10;
            transition: opacity 1s ease-out; padding: 20px;
        }
        h1 { color: #ff4d79; font-size: 2rem; margin-bottom: 20px; }
        p.subtitle { color: #888; font-size: 1rem; margin-bottom: 30px; }
        button {
            padding: 15px 40px; font-size: 1.2rem;
            background-color: #ff4d79; color: white; border: none;
            border-radius: 50px; cursor: pointer;
            box-shadow: 0 4px 15px rgba(255, 77, 121, 0.4);
            touch-action: manipulation;
        }
        button:active { transform: scale(0.95); }
        #heart-container {
            position: relative; width: 100%; height: 100%; display: none;
        }
        .note {
            position: absolute; background: #fff;
            padding: 5px 10px; font-size: 12px; color: #555;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.1);
            border-radius: 4px; opacity: 0; white-space: nowrap;
            border-bottom: 3px solid #ffeff2;
            transition: all 2s cubic-bezier(0.25, 1, 0.5, 1);
            /* ✅ 新增：让纸条可点击 */
            cursor: pointer;
            touch-action: manipulation;
            z-index: 2;
        }
        /* ✅ 新增：点击后变成爱心的样式 */
        .note.is-heart {
            background: #ff4d79 !important;
            color: white !important;
            border-bottom-color: #d6335c !important;
            font-size: 16px !important;
            padding: 8px 12px !important;
            border-radius: 50% !important;
            box-shadow: 0 0 12px rgba(255, 77, 121, 0.6) !important;
            transform: scale(1.2) !important;
        }
        .center-card {
            position: absolute; top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            background: white; padding: 20px 30px;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            text-align: center; z-index: 5; opacity: 0;
            animation: popIn 1.5s forwards 5.5s; max-width: 85%;
        }
        .center-card h2 { margin: 0; color: #ff4d79; font-size: 1.4rem; }
        .center-card p { margin: 10px 0 0; color: #666; font-size: 1rem; }
        @keyframes popIn {
            0% { transform: translate(-50%, -50%) scale(0.5); opacity: 0; }
            100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
        }
        /* ✅ 感叹号标识大幅放大 */
        .hyl-badge {
            position: fixed; bottom: 15px; left: 15px;
            font-size: 28px;          /* 从18px→28px */
            color: #ccc; cursor: help;
            z-index: 999; user-select: none;
            padding: 15px;            /* 点击热区更大 */
            line-height: 1;
            transition: color 0.3s;
            touch-action: manipulation;
        }
    </style>
</head>
<body>
    <div id="welcome-screen">
        <h1>致顾斐老师 ❤️</h1>
        <p class="subtitle">学生：孙逸林 敬上</p>
        <button id="start-btn">开启惊喜</button>
    </div>
    <div id="heart-container">
        <div class="center-card">
            <h2>满心欢喜，皆源于您</h2>
            <p>祝顾老师天天开心！</p>
        </div>
    </div>
    <div class="hyl-badge" id="hyl-tip">❗</div>

    <script>
        const messages = [
            "桃李满天下","春晖遍四方","教诲如春风","师恩深似海",
            "身体健康","工作顺利","万事如意","笑口常开",
            "永远年轻","美丽大方","教学有成","生活美满",
            "Happy Day","Best Teacher","Good Luck","平安喜乐",
            "前程似锦","岁月静好","温柔以待","心想事成"
        ];

        document.getElementById('start-btn').addEventListener('click', function(){
            const ws = document.getElementById('welcome-screen');
            ws.style.opacity = '0';
            setTimeout(()=>{
                ws.style.display='none';
                document.getElementById('heart-container').style.display='block';
                createHeartNotes();
            },1000);
        });

        // 左下角标识点击逻辑（不变）
        const hylTip = document.getElementById('hyl-tip');
        let tipVisible = false;
        hylTip.addEventListener('click', function(){
            if(!tipVisible){
                this.innerText="此网页由 H YL 书写";
                this.style.color="#999"; tipVisible=true;
            } else {
                this.innerText="❗";
                this.style.color="#ccc"; tipVisible=false;
            }
        });

        function createHeartNotes(){
            const container = document.getElementById('heart-container');
            const totalNotes = 90;
            const centerX = window.innerWidth / 2;
            const centerY = window.innerHeight / 2;

            const sw = window.innerWidth;
            let scale = 14;
            if(sw < 400) scale = 11;
            else if(sw < 500) scale = 13;
            else if(sw < 800) scale = 14;
            else scale = 16;

            for(let i=0; i<totalNotes; i++){
                const note = document.createElement('div');
                note.classList.add('note');
                note.innerText = messages[Math.floor(Math.random()*messages.length)];

                const t = (Math.PI * 2 * i) / totalNotes;
                const targetX = 16 * Math.pow(Math.sin(t), 3);
                const targetY = -(13*Math.cos(t) - 5*Math.cos(2*t) - 2*Math.cos(3*t) - Math.cos(4*t));
                const finalX = centerX + targetX * scale;
                const finalY = centerY + targetY * scale;

                note.style.left = (Math.random()*window.innerWidth)+'px';
                note.style.top = (Math.random()*window.innerHeight)+'px';
                note.style.transform = `rotate(${(Math.random()-0.5)*60}deg) scale(0.8)`;
                container.appendChild(note);

                // 阶段二：飞向中心
                setTimeout(()=>{
                    note.style.opacity = '1';
                    note.style.left = centerX + 'px';
                    note.style.top = centerY + 'px';
                    note.style.transform = `rotate(${(Math.random()-0.5)*20}deg) scale(1)`;
                }, 600 + i*25);

                // 阶段三：散开成爱心
                setTimeout(()=>{
                    note.style.left = finalX + 'px';
                    note.style.top = finalY + 'px';
                    note.style.transform = `rotate(${(Math.random()-0.5)*10}deg) scale(1)`;
                }, 3200 + i*30);

                // ✅ 核心新增：点击纸条 → 变成爱心
                note.addEventListener('click', function(){
                    if(!this.classList.contains('is-heart')){
                        this.classList.add('is-heart');
                        this.innerText = '❤️';
                    }
                });
            }
        }
    </script>
</body>
</html>
